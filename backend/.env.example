# Minimal env example for Brevo transactional emails
# Required for production: BREVO_API_KEY and EMAIL_FROM
BREVO_API_KEY=
# The sender email address to use in `sender.email` for Brevo
EMAIL_FROM=no-reply@yourdomain.com
# Optional friendly sender name
FROM_NAME=Farm Direct

# Backend port
PORT=4000
NODE_ENV=development

# API Server
API_BASE_URL=http://localhost:4000

# CORS Settings
CORS_ORIGIN=http://localhost:8080

# Frontend Base URL (for password reset links)
FRONTEND_URL=http://localhost:8080

# Auto-wish (in-app activity log) settings
# Enable automatic wishes: true or false
AUTO_WISH_ENABLED=false
# Hour and minute in 24-hour time when daily auto-wish runs
AUTO_WISH_HOUR=09
AUTO_WISH_MINUTE=00
# Default auto-wish message
AUTO_WISH_MESSAGE=Good morning from Farm Direct! Have a great day.

# Debug mode - returns reset link in API response (development only, disable in production)
DEBUG_PASSWORD_RESET=false
DEBUG_OTP=false
