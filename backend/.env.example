# SMTP configuration (set these in your environment or a .env file)
# Example values — DO NOT commit real credentials to source control
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=Farm Direct <no-reply@yourdomain.com>

# Backend port
PORT=4000
# Backend Environment Variables
PORT=4000
NODE_ENV=development

# API Server
API_BASE_URL=http://localhost:4000

# CORS Settings
CORS_ORIGIN=http://localhost:8080

# Frontend Base URL (for password reset links)
FRONTEND_BASE=http://localhost:8080

# Auto-wish (in-app activity log) settings
# Enable automatic wishes: true or false
AUTO_WISH_ENABLED=false
# Hour and minute in 24-hour time when daily auto-wish runs
AUTO_WISH_HOUR=09
AUTO_WISH_MINUTE=00
# Default auto-wish message
AUTO_WISH_MESSAGE=Good morning from Farm Direct! Have a great day.

# Password Reset Email - Brevo SMTP Configuration
# Get these from your Brevo account at https://app.brevo.com/settings/smtp/
SMTP_HOST=smtp-brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASS=xsmtpsib-your-api-key-here
EMAIL_FROM=your-sender-email@example.com

# Debug mode - returns reset link in API response (development only, disable in production)
DEBUG_PASSWORD_RESET=false
